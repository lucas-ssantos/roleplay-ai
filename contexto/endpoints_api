# Personagens
POST   /api/characters
GET    /api/characters
GET    /api/characters/:id
PUT    /api/characters/:id
DELETE /api/characters/:id
POST   /api/characters/:id/duplicate   → clonar personagem

# Conversas
POST   /api/conversations
GET    /api/conversations
GET    /api/conversations/:id
DELETE /api/conversations/:id
GET    /api/conversations/:id/messages

# Chat
POST   /api/conversations/:id/messages              → enviar msg
POST   /api/conversations/:id/messages/:msgId/regenerate
PUT    /api/conversations/:id/messages/:msgId       → editar msg
DELETE /api/conversations/:id/messages/rollback/:msgId

# Memória
GET    /api/conversations/:id/memories
POST   /api/conversations/:id/memories              → criar manual
PUT    /api/conversations/:id/memories/:memId
DELETE /api/conversations/:id/memories/:memId
POST   /api/conversations/:id/memories/summarize    → forçar sumarização

# Lorebook
POST   /api/lorebooks
GET    /api/lorebooks
PUT    /api/lorebooks/:id
DELETE /api/lorebooks/:id
POST   /api/characters/:id/lorebooks/:lorebookId    → vincular ao personagem

# Configurações
GET    /api/settings
PUT    /api/settings                                → config global
GET    /api/conversations/:id/settings
PUT    /api/conversations/:id/settings              → override por conversa
GET    /api/settings/models                         → lista modelos do Ollama